---
// Importing necessary components
import Meta from "@components/Meta.astro";
import Navbar from "@components/sections/navbar&footer/Navbar.astro";
import FooterSection from "@components/sections/navbar&footer/FooterSection.astro";
import { SITE } from "@data/constants";
import "@styles/global.css";

// Setting expected props
const {
  title = SITE.title,
  meta,
  structuredData,
  lang = "zh-CN",
  customDescription = null,
  customOgTitle = null,
} = Astro.props;

// Interface to type-check the properties
interface Props {
  title?: string;
  meta?: string;
  structuredData?: object;
  lang?: string;
  customDescription?: string | null;
  customOgTitle?: string | null;
}
---

<html lang={lang} class="scrollbar-hide lenis lenis-smooth scroll-pt-16">
  <head>
    {/* Adding metadata to the HTML document */}
    <Meta
      meta={meta}
      structuredData={structuredData}
      customDescription={customDescription}
      customOgTitle={customOgTitle}
      lang={lang}
      locale={lang === "en" ? "en_US" : "zh_CN"}
    />
    {/* Define the title of the page */}
    <title>{title}</title>
    <script is:inline>
      const STORAGE_KEY = "hs_theme";
      const AUTO_THEME_START_HOUR = 7;
      const AUTO_THEME_END_HOUR = 19;

      const resolveAutoThemeByHour = (date = new Date()) => {
        const hour = date.getHours();
        return hour >= AUTO_THEME_START_HOUR && hour < AUTO_THEME_END_HOUR
          ? "light"
          : "dark";
      };

      const getStoredThemePreference = () => {
        const value = localStorage.getItem(STORAGE_KEY);
        return value === "light" || value === "dark" || value === "auto"
          ? value
          : null;
      };

      const getEffectiveTheme = (preference) => {
        if (preference === "light" || preference === "dark") return preference;
        return resolveAutoThemeByHour();
      };

      const syncThemeToggleUi = (theme) => {
        document.querySelectorAll(".theme-toggle-light").forEach((button) => {
          button.classList.toggle("hidden", theme === "dark");
          button.classList.toggle("flex", theme !== "dark");
        });

        document.querySelectorAll(".theme-toggle-dark").forEach((button) => {
          button.classList.toggle("hidden", theme !== "dark");
          button.classList.toggle("flex", theme === "dark");
        });
      };

      const applyTheme = (theme) => {
        document.documentElement.classList.toggle("dark", theme === "dark");
        document.documentElement.dataset.theme = theme;
        syncThemeToggleUi(theme);
      };

      const setThemePreference = (preference) => {
        localStorage.setItem(STORAGE_KEY, preference);
        applyTheme(getEffectiveTheme(preference));
      };

      const syncTheme = () => {
        applyTheme(getEffectiveTheme(getStoredThemePreference()));
      };

      window.__siteTheme = {
        applyTheme,
        setThemePreference,
        syncTheme,
      };

      syncTheme();
    </script>
    <script>
      import "@scripts/lenisSmoothScroll.js";
    </script>
  </head>
  <!-- <body
    class="bg-neutral-200 selection:bg-yellow-400 selection:text-neutral-700 dark:bg-neutral-800 flex flex-col min-h-screen"
  > -->
  <!-- <body
    class="bg-neutral-200 selection:bg-primary-blue/80 selection:text-neutral-300 dark:bg-background-dark flex flex-col min-h-screen"
  > -->
  <body class="theme-body flex min-h-screen flex-col selection:bg-primary-blue/20 selection:text-[var(--text-strong)]">
    {/*
    Setting up the main structure of the page.
    The Navbar is placed at the top, with a slot for the main content and FooterSection at the bottom.
    */}
    <!-- <div class="w-full mx-auto max-w-(--breakpoint-2xl) px-4 sm:px-6 lg:px-8 flex-grow"> -->
    <div class="mx-auto flex w-full max-w-full flex-col flex-grow text-[var(--text-body)]">
      <Navbar />
      <main>
        <slot />
      </main>
    </div>
    <FooterSection />
    <script is:inline>
      if (!window.__siteThemeClickBound) {
        document.addEventListener("click", (event) => {
          const toggle =
            event.target instanceof Element
              ? event.target.closest("[data-theme-toggle]")
              : null;

          if (!(toggle instanceof HTMLElement)) return;

          const nextTheme = toggle.getAttribute("data-theme-toggle");
          if (nextTheme === "light" || nextTheme === "dark") {
            window.__siteTheme?.setThemePreference(nextTheme);
          }
        });

        window.__siteThemeClickBound = true;
      }

      window.__siteTheme?.syncTheme();
      document.addEventListener("astro:page-load", () => {
        window.__siteTheme?.syncTheme();
      });
    </script>
    <script>
      // https://preline.co
      import "preline/preline.js";
    </script>
    <style>
      /* CSS rules for the page scrollbar */
      .scrollbar-hide::-webkit-scrollbar {
        display: none;
      }

      .scrollbar-hide {
        -ms-overflow-style: none;
        scrollbar-width: none;
      }
    </style>
  </body>
</html>
