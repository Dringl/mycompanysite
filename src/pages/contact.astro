---
import MainLayout from "@/layouts/MainLayout.astro";
import ContactSection from "@components/sections/misc/ContactSection.astro";
import { COMPANY_INFO } from "@data/company";
import { SITE } from "@data/constants";

const pageTitle = `联系我们｜${COMPANY_INFO.shortName}`;
const metaDescription = COMPANY_INFO.contactIntro;
const canonicalUrl = `${SITE.url}/contact`;
---

<MainLayout
  title={pageTitle}
  customDescription={metaDescription}
  customOgTitle={pageTitle}
  structuredData={{
    "@context": "https://schema.org",
    "@type": "ContactPage",
    "@id": canonicalUrl,
    url: canonicalUrl,
    name: `${COMPANY_INFO.shortName} 联系我们`,
    description: metaDescription,
    isPartOf: {
      "@type": "WebSite",
      url: SITE.url,
      name: SITE.title,
      description: SITE.description,
    },
    inLanguage: "zh-CN",
  }}
>
  <ContactSection />
</MainLayout>
