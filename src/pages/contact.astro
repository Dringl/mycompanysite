---
import MainLayout from "@/layouts/MainLayout.astro";
import ContactSection from "@components/sections/misc/ContactSection.astro";
import { COMPANY_INFO } from "@data/company";
import { SITE } from "@data/constants";

const pageTitle = `联系我们｜${COMPANY_INFO.shortName}`;
const metaDescription = COMPANY_INFO.contactIntro;
const canonicalUrl = `${SITE.url}/contact`;
---

<MainLayout
  title={pageTitle}
  customDescription={metaDescription}
  customOgTitle={pageTitle}
  structuredData={{
    "@context": "https://schema.org",
    "@type": "ContactPage",
    "@id": canonicalUrl,
    url: canonicalUrl,
    name: `${COMPANY_INFO.shortName} 联系我们`,
    description: metaDescription,
    isPartOf: {
      "@type": "WebSite",
      url: SITE.url,
      name: SITE.title,
      description: SITE.description,
    },
    inLanguage: "zh-CN",
  }}
>
  <ContactSection
    title="联系我们"
    subTitle={COMPANY_INFO.contactIntro}
    formTitle="提交咨询需求"
    formSubTitle="填写基础信息后，我们会尽快与你联系。"
    submitLabel={COMPANY_INFO.ctaLabel}
    phoneLabel="咨询电话"
    phoneName="刘先生"
    phoneNumber="86-18622472119"
  />
</MainLayout>
