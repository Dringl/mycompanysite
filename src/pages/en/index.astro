---
import { Image } from "astro:assets";
import MainLayout from "@/layouts/MainLayout.astro";
import HeroSection from "@components/sections/landing/HeroSection.astro";
import HeroSectionAlt from "@components/sections/landing/HeroSectionAlt.astro";
import FeaturesGeneral from "@components/sections/features/FeaturesGeneral.astro";
import FeaturesNavs from "@components/sections/features/FeaturesNavs.astro";
import FeaturesStatsAlt from "@components/sections/features/FeaturesStatsAlt.astro";
import FAQ from "@components/sections/misc/FAQ.astro";
import VideoShowcase from "@components/sections/landing/VideoShowcase.astro";
import PrimaryCTA from "@/components/ui/buttons/PrimaryCTA.astro";
import SecondaryCTA from "@/components/ui/buttons/SecondaryCTA.astro";
import {
  EN_COMPANY_ADVANTAGES,
  EN_COMPANY_INFO,
  EN_FAQS,
  EN_HOME_ADVANTAGE_VISUAL,
  EN_HOME_CASE_HIGHLIGHTS,
  EN_HOME_CASE_SECTION,
  EN_HOME_CLOSING_CTA,
  EN_HOME_FEATURES,
  EN_HOME_PILLARS,
  EN_HOME_SOLUTION_TABS,
} from "@data/company.en";

const pageTitle = `${EN_COMPANY_INFO.shortName} | ${EN_COMPANY_INFO.tagline}`;
---

<MainLayout
  title={pageTitle}
  customDescription={EN_COMPANY_INFO.description}
  customOgTitle={pageTitle}
  lang="en"
>
  <HeroSection
    tagline={EN_COMPANY_INFO.hero.tagline}
    title={EN_COMPANY_INFO.hero.title}
    brandTitle={EN_COMPANY_INFO.hero.brandTitle}
    subTitle={EN_COMPANY_INFO.hero.subTitle}
    primaryBtnText={EN_COMPANY_INFO.hero.primaryText}
    primaryBtnUrl={EN_COMPANY_INFO.hero.primaryUrl}
    secondaryBtnText={EN_COMPANY_INFO.hero.secondaryText}
    secondaryBtnUrl={EN_COMPANY_INFO.hero.secondaryUrl}
  />

  <div class="mx-auto w-full max-w-(--breakpoint-2xl) flex-grow px-4 sm:px-6 lg:px-8">
    <FeaturesGeneral
      title="Core Business Capabilities"
      subTitle="Build a four-layer capability structure around equipment parts, core systems, modular chassis, and deployment-oriented solution services."
      pillars={EN_HOME_PILLARS}
      features={[...EN_HOME_FEATURES]}
    />

    <FeaturesNavs title="Key Solution Directions" tabs={EN_HOME_SOLUTION_TABS} />

    <VideoShowcase
      title="Understand Buquanxing Tech through a short video"
      subTitle="We focus on how unmanned equipment actually enters real operations: how parts and systems are combined, how chassis platforms are reused, and how solution services are deployed."
      videoUrl="/videos/company-intro-h264.mp4"
      highlights={[
        "The first impression stays centered on an unmanned equipment company, not a single-industry equipment vendor.",
        "Core business areas focus on parts supply, system supply, modular chassis, and scenario solution services.",
        "Agriculture is a key direction, while campuses, inspection, public services, and multi-mission platforms are also in scope.",
      ]}
      ctaTitle="Learn About Us"
      ctaUrl="/en/about"
    />

    <section class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14 2xl:max-w-full">
      <div class="mb-8 flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
        <div class="max-w-2xl">
          <h2 class="text-balance text-3xl font-bold text-neutral-800 dark:text-neutral-200 lg:text-4xl">
            {EN_HOME_CASE_SECTION.title}
          </h2>
          <p class="mt-3 text-pretty leading-8 text-neutral-600 dark:text-neutral-400">
            {EN_HOME_CASE_SECTION.subTitle}
          </p>
        </div>
        <PrimaryCTA title={EN_HOME_CASE_SECTION.ctaText} url={EN_HOME_CASE_SECTION.ctaUrl} />
      </div>

      <div class="grid gap-6 lg:grid-cols-3">
        {
          EN_HOME_CASE_HIGHLIGHTS.map((item) => (
            <article class="group relative overflow-hidden rounded-3xl border border-white/10 bg-neutral-950 p-6 shadow-xl transition duration-300 hover:-translate-y-1">
              <Image
                src={item.image}
                alt={item.title}
                class="absolute inset-0 h-full w-full object-cover transition duration-500 group-hover:scale-105"
                sizes="(min-width: 1024px) 30vw, 100vw"
              />
              <div class="absolute inset-0 bg-linear-to-t from-neutral-950 via-neutral-950/70 to-neutral-950/15 transition duration-300 group-hover:from-neutral-900"></div>
              <div class="relative z-10 flex min-h-[320px] flex-col justify-between">
                <span class="inline-flex w-fit rounded-full border border-white/10 bg-white/10 px-3 py-1 text-xs font-medium tracking-[0.18em] text-white/80 uppercase">
                  {item.tag}
                </span>
                <div>
                  <h3 class="text-2xl font-bold text-white">{item.title}</h3>
                  <p class="mt-3 text-sm leading-7 text-white/75">
                    {item.summary}
                  </p>
                  <div class="mt-6">
                    <SecondaryCTA title="View Details" url={item.href} />
                  </div>
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <FeaturesStatsAlt
      title="Why Buquanxing Tech"
      subTitle="Advance projects from capability assembly to real deployment through foundational unmanned equipment capability, modular platform thinking, and solution-service coordination."
      benefits={[...EN_COMPANY_ADVANTAGES]}
      src={EN_HOME_ADVANTAGE_VISUAL.src}
      alt={EN_HOME_ADVANTAGE_VISUAL.alt}
    />

    <FAQ title="Frequently Asked Questions" faqs={EN_FAQS} />

    <HeroSectionAlt
      title={EN_HOME_CLOSING_CTA.title}
      subTitle={EN_HOME_CLOSING_CTA.subTitle}
      buttonTitle={EN_HOME_CLOSING_CTA.buttonText}
      url={EN_HOME_CLOSING_CTA.url}
    />
  </div>
</MainLayout>
