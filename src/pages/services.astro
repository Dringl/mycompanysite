---
import MainLayout from "@/layouts/MainLayout.astro";
import MainSection from "@components/ui/blocks/MainSection.astro";
import LeftSection from "@components/ui/blocks/LeftSection.astro";
import RightSection from "@components/ui/blocks/RightSection.astro";
import FeaturesStats from "@components/sections/features/FeaturesStats.astro";
import ProductCatalog from "@components/sections/features/ProductCatalog.astro";

import servicesSection01Image01 from "@images/pages/services/services-section-01-image-01.png";
import servicesSection01Image02 from "@images/pages/services/services-section-01-image-02.png";
import servicesSection02Image from "@images/pages/services/services-section-02-image.jpeg";
import servicesSection03Image01 from "@images/pages/services/services-section-03-image-01.png";
import servicesSection03Image02 from "@images/pages/services/services-section-03-image-02.jpeg";
import servicesSection04Image from "@images/pages/services/services-section-04-image.jpeg";
import { SITE } from "@data/constants";
import { servicesPageContent } from "@data/company";

interface RightArticle {
  type: "right";
  title: string;
  subTitle: string;
  single?: boolean;
  imgOne: any;
  imgOneAlt: string;
  imgTwo?: any;
  imgTwoAlt?: string;
  btnExists?: boolean;
  btnTitle?: string;
  btnURL?: string;
}

interface LeftArticle {
  type: "left";
  title: string;
  subTitle: string;
  img: any;
  imgAlt: string;
  btnExists?: boolean;
  btnTitle?: string;
  btnURL?: string;
}

const serviceSections = servicesPageContent.sections;

const sectionImages: (RightArticle | LeftArticle)[] = [
  {
    type: "right",
    title: serviceSections[0].title,
    subTitle: serviceSections[0].subTitle,
    single: serviceSections[0].single,
    imgOneAlt: serviceSections[0].imgOneAlt,
    imgTwoAlt: serviceSections[0].imgTwoAlt,
    btnExists: serviceSections[0].btnExists,
    btnTitle: serviceSections[0].btnTitle,
    btnURL: serviceSections[0].btnURL,
    imgOne: servicesSection01Image01,
    imgTwo: servicesSection01Image02,
  },
  {
    type: "left",
    title: serviceSections[1].title,
    subTitle: serviceSections[1].subTitle,
    imgAlt: serviceSections[1].imgAlt,
    btnExists: serviceSections[1].btnExists,
    btnTitle: serviceSections[1].btnTitle,
    btnURL: serviceSections[1].btnURL,
    img: servicesSection02Image,
  },
  {
    type: "right",
    title: serviceSections[2].title,
    subTitle: serviceSections[2].subTitle,
    single: serviceSections[2].single,
    imgOneAlt: serviceSections[2].imgOneAlt,
    imgTwoAlt: serviceSections[2].imgTwoAlt,
    imgOne: servicesSection03Image01,
    imgTwo: servicesSection03Image02,
  },
  {
    type: "left",
    title: serviceSections[3].title,
    subTitle: serviceSections[3].subTitle,
    imgAlt: serviceSections[3].imgAlt,
    btnExists: serviceSections[3].btnExists,
    btnTitle: serviceSections[3].btnTitle,
    btnURL: serviceSections[3].btnURL,
    img: servicesSection04Image,
  },
];

const pageTitle = `产品与服务 | ${SITE.title}`;
const metaDescription =
  "补全星科技围绕无人化零件供应、核心部件供应、模块化通用底盘与方案服务，提供面向真实场景的一体化产品与服务能力。";
const ogTitle = "产品与服务 | 补全星科技";
const servicesUrl = new URL("/services", SITE.url).toString();
---

<MainLayout
  title={pageTitle}
  customDescription={metaDescription}
  customOgTitle={ogTitle}
  structuredData={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": servicesUrl,
    url: servicesUrl,
    name: "补全星科技产品与服务",
    description: metaDescription,
    isPartOf: {
      "@type": "WebSite",
      url: SITE.url,
      name: SITE.title,
      description: SITE.description,
    },
    inLanguage: "zh-CN",
  }}
>
  <div
    class="mx-auto w-full max-w-(--breakpoint-2xl) flex-grow px-4 sm:px-6 lg:px-8"
  >
    <MainSection
      title={servicesPageContent.hero.title}
      subTitle={servicesPageContent.hero.subTitle}
      btnExists={servicesPageContent.hero.btnExists}
      btnTitle={servicesPageContent.hero.btnTitle}
      btnURL={servicesPageContent.hero.btnURL}
    />

    <ProductCatalog />

    {
      sectionImages.map((article) => {
        return article.type === "right" ? (
          <RightSection
            title={article.title}
            subTitle={article.subTitle}
            single={article.single}
            imgOne={article.imgOne}
            imgOneAlt={article.imgOneAlt}
            imgTwo={article.imgTwo}
            imgTwoAlt={article.imgTwoAlt}
            btnExists={article.btnExists}
            btnTitle={article.btnTitle}
            btnURL={article.btnURL}
          />
        ) : (
          <LeftSection
            title={article.title}
            subTitle={article.subTitle}
            img={article.img}
            imgAlt={article.imgAlt}
            btnExists={article.btnExists}
            btnTitle={article.btnTitle}
            btnURL={article.btnURL}
          />
        );
      })
    }

    <FeaturesStats
      title={servicesPageContent.stats.title}
      subTitle={servicesPageContent.stats.subTitle}
      mainStatTitle={servicesPageContent.stats.mainStatTitle}
      mainStatSubTitle={servicesPageContent.stats.mainStatSubTitle}
      stats={[...servicesPageContent.stats.items]}
    />
  </div>
</MainLayout>
