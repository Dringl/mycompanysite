---
import MainLayout from "@/layouts/MainLayout.astro";
import PrimaryCTA from "@components/ui/buttons/PrimaryCTA.astro";
import CardSmall from "@components/ui/cards/CardSmall.astro";
import CardWide from "@components/ui/cards/CardWide.astro";
import FeaturesStatsAlt from "@components/sections/features/FeaturesStatsAlt.astro";
import TestimonialsSectionAlt from "@components/sections/testimonials/TestimonialsSectionAlt.astro";
import projectsTestimonialAvatar01 from "@images/pages/projects/projects-testimonial-avatar-01.jpeg";
import projectsTestimonialAvatar02 from "@images/pages/projects/projects-testimonial-avatar-02.jpeg";
import projectsTestimonialAvatar03 from "@images/pages/projects/projects-testimonial-avatar-03.jpeg";
import projectsStatsImage from "@images/pages/projects/projects-stats-image.jpeg";

// Importing necessary functions from Astro
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { SITE } from "@data/constants";

// Fetching all the product related content and sorting it by main.id
const product: CollectionEntry<"products">[] = (
  await getCollection("products")
).sort(
  (a: CollectionEntry<"products">, b: CollectionEntry<"products">) =>
    a.data.main.id - b.data.main.id
);

// Define variables for page content
const title: string = "客户案例";
const subTitle: string =
  "聚焦补全星科技在无人化零件供应、核心部件供应、通用底盘与方案服务方向的典型落地案例。";

// Testimonial data that will be rendered in the component
const testimonials = [
  {
    content:
      "“补全星科技在零件与部件配套上给了我们很大的帮助，很多本来会卡在适配和采购节奏的问题，被提前化解掉了。”",
    author: "李工",
    role: "无人化项目集成负责人",
    avatarSrc: projectsTestimonialAvatar01.src,
    avatarAlt: "无人化项目集成负责人头像",
  },
  {
    content:
      "“通用底盘方案让我们少走了很多弯路，后面新场景进来时不用再从头搭一套，扩展效率高很多。”",
    author: "王敏",
    role: "平台产品经理",
    avatarSrc: projectsTestimonialAvatar02.src,
    avatarAlt: "平台产品经理头像",
  },
  {
    content:
      "“方案服务不是只给一份文档，而是真的陪着我们把部署顺下来，这对项目推进特别重要。”",
    author: "陈总",
    role: "场景项目负责人",
    avatarSrc: projectsTestimonialAvatar03.src,
    avatarAlt: "场景项目负责人头像",
  },
];

const pageTitle: string = `客户案例 | ${SITE.title}`;
const metaDescription =
  "查看补全星科技在无人化零件供应、核心部件供应、通用底盘与方案服务方向的典型案例与落地经验。";
const ogTitle = `客户案例 | ${SITE.title}`;
const projectsUrl = new URL("/projects", SITE.url).toString();
---

<MainLayout
  title={pageTitle}
  customDescription={metaDescription}
  customOgTitle={ogTitle}
  structuredData={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": projectsUrl,
    url: projectsUrl,
    name: `客户案例 | ${SITE.title}`,
    description:
      "查看补全星科技在无人化零件供应、核心部件供应、通用底盘与方案服务方向的客户案例。",
    isPartOf: {
      "@type": "WebSite",
      url: SITE.url,
      name: SITE.title,
      description: SITE.description,
    },
    inLanguage: "zh-CN",
  }}
>
  <div
    class="mx-auto w-full max-w-(--breakpoint-2xl) flex-grow px-4 sm:px-6 lg:px-8"
  >
    <div
      class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14 2xl:max-w-full"
    >
      <div
        class="mb-4 flex items-center justify-between gap-8 sm:mb-8 md:mb-12"
      >
        <div class="flex items-center gap-12">
          <h1
            class="text-2xl font-bold tracking-tight text-balance text-neutral-800 md:text-4xl md:leading-tight dark:text-neutral-200"
          >
            {title}
          </h1>
          {
            subTitle && (
              <p class="hidden max-w-(--breakpoint-sm) text-pretty text-neutral-600 md:block dark:text-neutral-400">
                {subTitle}
              </p>
            )
          }
        </div>
        <PrimaryCTA title="查看客户反馈" url="#testimonials" noArrow={true} />
      </div>
      {
        /* Displaying products in alternating styles. Alternative product gets different card styling.
    Maps through all product entries and displays them with either CardSmall or CardWide based on their position. */
      }
      <section class="grid grid-cols-1 gap-4 sm:grid-cols-3 md:gap-6 xl:gap-8">
        {
          product.map((product, index) => {
            const position = index % 4;
            if (position === 0 || position === 3) {
              return <CardSmall product={product} />;
            } else {
              return <CardWide product={product} />;
            }
          })
        }
      </section>
    </div>
    {/* Features statistics section */}
    <FeaturesStatsAlt
      title="为什么选择补全星科技"
      subTitle="我们将农业社会化服务经验、智能装备研发能力与场景交付方法结合起来，帮助客户从试点验证走向规模落地，在真实业务环境中持续创造可衡量的成果。"
      benefits={[
        "聚焦农业与无人化场景，方案更贴近真实业务流程与现场约束。",
        "覆盖平台、设备、实施与培训协同，减少从方案到落地的断层。",
        "坚持长期陪跑与迭代优化，帮助客户沉淀可复制的运营能力。",
      ]}
      src={projectsStatsImage}
      alt="丘陵山地与无人化装备应用场景"
    />
    {/* Testimonials section */}
    <TestimonialsSectionAlt
      title="客户反馈"
      testimonials={testimonials}
    />
  </div>
</MainLayout>
