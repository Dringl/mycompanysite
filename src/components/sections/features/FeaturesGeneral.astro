---
import { Image } from "astro:assets";
import IconBlock from "@components/ui/blocks/IconBlock.astro";
import Icon from "@components/ui/icons/Icon.astro";

interface Feature {
  heading: string;
  content: string;
  svg: string;
}

interface Pillar {
  title: string;
  summary: string;
  image: any;
}

interface Props {
  title?: string;
  subTitle?: string;
  features?: Feature[];
  pillars?: Pillar[];
}

const { title, subTitle, features, pillars = [] } = Astro.props;
---

<section class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14 2xl:max-w-full">
  {
    pillars.length > 0 && (
      <div class="mb-16 grid gap-6 md:grid-cols-2 xl:grid-cols-4">
        {pillars.map((pillar, index) => (
          <div
            class={`group relative min-h-[340px] overflow-hidden rounded-2xl border border-white/10 bg-neutral-950 ${index % 2 === 1 ? "xl:mt-10" : ""}`}
          >
            <Image
              src={pillar.image}
              alt={pillar.title}
              class="absolute inset-0 h-full w-full object-cover transition duration-500 group-hover:scale-105"
              sizes="(min-width: 1280px) 22rem, (min-width: 768px) 50vw, 100vw"
            />
            <div class="absolute inset-0 bg-linear-to-t from-neutral-950 via-neutral-950/60 to-neutral-950/15 transition duration-300 group-hover:from-neutral-900 group-hover:via-neutral-950/45"></div>
            <div class="absolute inset-0 bg-linear-to-br from-primary-blue/10 via-transparent to-cyan-300/10 opacity-80 mix-blend-screen transition duration-300 group-hover:opacity-100"></div>
            <div class="absolute inset-x-0 bottom-0 z-10 p-6">
              <h3 class="text-2xl font-bold text-white">{pillar.title}</h3>
              <p class="mt-3 text-sm leading-7 text-white/75">{pillar.summary}</p>
            </div>
          </div>
        ))}
      </div>
    )
  }

  <div class="mt-5 grid gap-8 lg:mt-16 lg:grid-cols-3 lg:gap-12">
    <div class="lg:col-span-1">
      <h2 class="text-balance text-2xl font-bold text-neutral-800 dark:text-neutral-200 md:text-3xl">
        {title}
      </h2>
      {
        subTitle && (
          <p class="mt-2 text-pretty text-neutral-600 dark:text-neutral-400 md:mt-4">
            {subTitle}
          </p>
        )
      }
    </div>

    <div class="lg:col-span-2">
      <div class="grid gap-8 sm:grid-cols-2 md:gap-12">
        {
          features &&
            features.map((feature) => (
              <IconBlock heading={feature.heading} content={feature.content}>
                <Icon name={feature.svg} />
              </IconBlock>
            ))
        }
      </div>
    </div>
  </div>
</section>
