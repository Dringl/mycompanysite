---
//Import relevant dependencies
import ThemeIcon from "@components/ThemeIcon.astro";
import NavLink from "@components/ui/links/NavLink.astro";
import navigation from "@utils/navigation.ts";
import { COMPANY_INFO, COMPANY_LINKS } from "@data/company";
import brandIcon from "@images/logo.png";
import { Image } from "astro:assets";

const strings = navigation;
const homeUrl = COMPANY_LINKS.home;
---

<!-- Main header component -->
<header
  class="sticky inset-x-0 top-4 z-50 flex flex-wrap text-sm md:flex-nowrap md:justify-start w-full mx-auto max-w-(--breakpoint-2xl) px-4 sm:px-6 lg:px-8"
>
  <!-- Navigation container -->
  <!-- <nav
    class="relative mx-2 w-full rounded-[36px] border border-yellow-100/40 bg-yellow-50/60 px-4 py-3 backdrop-blur-md dark:border-neutral-700/40 dark:bg-neutral-800/80 dark:backdrop-blur-md md:flex md:items-center md:justify-between md:px-6 md:py-0 lg:px-8 xl:mx-auto"
    aria-label="Global"
  > -->
  <nav
    class="relative mx-2 w-full rounded-[36px] border border-[color:var(--border-soft)] bg-[color:var(--surface-1)]/88 px-4 py-3 shadow-[0_20px_60px_rgba(15,23,42,0.08)] backdrop-blur-md md:flex md:items-center md:justify-between md:px-6 md:py-0 lg:px-8 xl:mx-auto"
    aria-label="Global"
  >
    <div class="flex items-center justify-between md:my-3 lg:my-3 xl:my-3">
      <!-- Brand logo -->
      <a
        class="flex-none rounded-lg text-xl font-bold outline-hidden ring-zinc-500 focus-visible:ring-3 dark:ring-zinc-200 dark:focus:outline-hidden"
        href={homeUrl}
        aria-label="Brand"
      >
        <!-- <BrandLogo class="h-auto w-24" /> -->
        <Image src={brandIcon} alt={`${COMPANY_INFO.shortName} Logo`} class="h-auto w-13" loading="lazy"/>
      </a>
      <!-- Collapse toggle for smaller screens -->
      <div class="ml-auto mr-5 md:hidden">
        <button
          type="button"
          class="hs-collapse-toggle flex h-8 w-8 items-center justify-center rounded-full text-sm font-bold text-[color:var(--text-body)] transition duration-300 hover:bg-[color:var(--surface-2)] disabled:pointer-events-none disabled:opacity-50"
          data-hs-collapse="#navbar-collapse-with-animation"
          aria-controls="navbar-collapse-with-animation"
          aria-label="Toggle navigation"
        >
          <svg
            class="h-[1.25rem] w-[1.25rem] shrink-0 hs-collapse-open:hidden"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <line x1="3" x2="21" y1="6" y2="6"></line>
            <line x1="3" x2="21" y1="12" y2="12"></line>
            <line x1="3" x2="21" y1="18" y2="18"></line>
          </svg>
          <svg
            class="hidden h-[1.25rem] w-[1.25rem] shrink-0 hs-collapse-open:block"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M18 6 6 18"></path>
            <path d="m6 6 12 12"></path>
          </svg>
        </button>
      </div>
      <!-- ThemeIcon component specifically for smaller screens -->
      <span class="inline-block md:hidden">
        <ThemeIcon />
      </span>
    </div>
    <!-- Contains navigation links -->
    <div
      id="navbar-collapse-with-animation"
      class="hs-collapse hidden grow basis-full overflow-hidden transition-all duration-300 md:block"
    >
      <!-- Navigation links container -->
      <div
        class="mt-5 flex flex-col gap-x-0 gap-y-4 md:mt-0 md:flex-row md:items-center md:justify-end md:gap-x-4 lg:gap-x-7 md:gap-y-0 md:ps-7"
      >
        <!-- Navigation links and Authentication component -->
        {strings.navBarLinks.map(link => (
          <NavLink url={link.url} name={link.name} />
        ))}

        <a
          href={COMPANY_LINKS.contact}
          class="inline-flex items-center justify-center rounded-full bg-primary-blue px-5 py-2 text-sm font-semibold text-white transition duration-300 hover:bg-primary-blue/80 focus-visible:outline-hidden focus-visible:ring-3 focus-visible:ring-zinc-500 dark:focus-visible:ring-zinc-200"
        >
          {COMPANY_INFO.ctaLabel}
        </a>

        <!-- ThemeIcon component specifically for larger screens -->
        <span class="hidden md:inline-block">
          <ThemeIcon />
        </span>
      </div>
    </div>
  </nav>
</header>
<!-- Theme Appearance script to manage light/dark modes -->
<script is:inline>
  const STORAGE_KEY = "hs_theme";
  const AUTO_THEME_START_HOUR = 7;
  const AUTO_THEME_END_HOUR = 19;

  const resolveAutoThemeByHour = (date = new Date()) => {
    const hour = date.getHours();
    return hour >= AUTO_THEME_START_HOUR && hour < AUTO_THEME_END_HOUR
      ? "light"
      : "dark";
  };

  const getStoredThemePreference = () => {
    const value = localStorage.getItem(STORAGE_KEY);
    return value === "light" || value === "dark" || value === "auto"
      ? value
      : null;
  };

  const getEffectiveTheme = (preference) => {
    if (preference === "light" || preference === "dark") return preference;
    return resolveAutoThemeByHour();
  };

  const applyTheme = (theme) => {
    document.documentElement.classList.toggle("dark", theme === "dark");
    document.documentElement.dataset.theme = theme;

    document.querySelectorAll(".theme-toggle-light").forEach((button) => {
      button.classList.toggle("hidden", theme === "dark");
      button.classList.toggle("flex", theme !== "dark");
    });

    document.querySelectorAll(".theme-toggle-dark").forEach((button) => {
      button.classList.toggle("hidden", theme !== "dark");
      button.classList.toggle("flex", theme === "dark");
    });
  };

  const setThemePreference = (preference) => {
    localStorage.setItem(STORAGE_KEY, preference);
    applyTheme(getEffectiveTheme(preference));
  };

  const syncTheme = () => {
    applyTheme(getEffectiveTheme(getStoredThemePreference()));
  };

  window.addEventListener("load", () => {
    syncTheme();

    document.querySelectorAll("[data-theme-toggle]").forEach((button) => {
      button.addEventListener("click", () => {
        const nextTheme = button.getAttribute("data-theme-toggle");
        if (nextTheme === "light" || nextTheme === "dark") {
          setThemePreference(nextTheme);
        }
      });
    });
  });
</script>
