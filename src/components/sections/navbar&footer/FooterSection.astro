---
import { getNavigation } from "@utils/navigation.ts";
import { COMPANY_INFO, COMPANY_LINKS, aboutPageContent } from "@data/company";
import { EN_COMPANY_INFO, EN_ABOUT_PAGE_CONTENT } from "@data/company.en";
import brandIcon from "@images/logo.png";
import { Image } from "astro:assets";

const pathname = Astro.url.pathname;
const isEnglish = pathname === "/en" || pathname.startsWith("/en/");
const strings = getNavigation(isEnglish);
const companyInfo = isEnglish ? EN_COMPANY_INFO : COMPANY_INFO;
const footerContent = isEnglish ? EN_ABOUT_PAGE_CONTENT.footer : aboutPageContent.footer;
const brandDescription = companyInfo.footerNote;
const contactIntro = companyInfo.contactIntro;
const contactHeading = isEnglish ? "Contact Us" : "联系我们";
const contactButtonLabel = isEnglish ? EN_COMPANY_INFO.ctaLabel : COMPANY_INFO.ctaLabel;
const contactUrl = isEnglish ? "/en/contact" : COMPANY_LINKS.contact;
const currentYear = new Date().getFullYear();
---

<footer class="w-full bg-[radial-gradient(circle_at_top,_rgba(255,255,255,0.72),_rgba(245,246,248,0.96))] dark:bg-[radial-gradient(circle_at_top,_rgba(15,23,42,0.92),_rgba(2,6,23,1))]">
  <div
    class="mx-auto w-full max-w-[85rem] px-4 py-10 sm:px-6 lg:px-16 lg:pt-20 2xl:max-w-(--breakpoint-2xl)"
  >
    <div class="grid grid-cols-2 gap-6 md:grid-cols-4 lg:grid-cols-5">
      <div class="col-span-full lg:col-span-2">
        <div class="inline-flex items-center gap-3 rounded-[1.75rem] border border-[color:var(--border-soft)] bg-white/70 px-4 py-3 shadow-[0_16px_40px_rgba(15,23,42,0.08)] backdrop-blur-sm dark:bg-white/5">
          <Image src={brandIcon} alt={`${companyInfo.shortName} Logo`} class="h-10 w-10 object-contain" />
          <div class="space-y-1">
            <p class="text-xs font-semibold uppercase tracking-[0.24em] text-[color:var(--text-soft)]">
              {footerContent.ctaTitle}
            </p>
            <h3 class="text-lg font-bold text-neutral-800 dark:text-neutral-100">
              {companyInfo.name}
            </h3>
          </div>
        </div>
        <div class="mt-4 max-w-md space-y-3">
          <p class="text-sm leading-6 text-neutral-600 dark:text-neutral-400">
            {brandDescription}
          </p>
        </div>
      </div>
      {
        strings.footerLinks.map((section) => (
          <div class="col-span-1">
            <h3 class="font-bold text-neutral-800 dark:text-neutral-200">
              {section.section}
            </h3>
            <ul class="mt-3 grid space-y-3">
              {section.links.map((link) => (
                <li>
                  <a
                    href={link.url}
                    class="inline-flex gap-x-2 rounded-lg text-neutral-600 outline-hidden ring-zinc-500 transition duration-300 hover:text-neutral-500 focus-visible:ring-3 dark:text-neutral-400 dark:ring-zinc-200 dark:hover:text-neutral-300 dark:focus:outline-hidden"
                  >
                    {link.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }

      <div class="col-span-2">
        <h3 class="font-bold text-neutral-800 dark:text-neutral-200">
          {contactHeading}
        </h3>
        <div class="mt-3 space-y-4">
          <p class="text-sm leading-6 text-neutral-600 dark:text-neutral-400">
            {contactIntro}
          </p>
          <a
            href={contactUrl}
            class="inline-flex items-center justify-center rounded-full bg-neutral-900 px-5 py-2 text-sm font-semibold text-neutral-50 transition duration-300 hover:bg-neutral-700 focus-visible:outline-hidden focus-visible:ring-3 focus-visible:ring-zinc-500 dark:bg-primary-blue dark:hover:bg-primary-blue/80 dark:focus-visible:ring-zinc-200"
          >
            {contactButtonLabel}
          </a>
        </div>
      </div>
    </div>

    <div
      class="mt-9 grid gap-y-3 border-t border-neutral-400/40 pt-6 sm:mt-12 sm:flex sm:items-center sm:justify-between sm:gap-y-0 dark:border-neutral-700/40"
    >
      <div class="flex items-center justify-between">
        <p class="text-sm text-neutral-600 dark:text-neutral-400">
          © {currentYear} {companyInfo.name}。{footerContent.copyright}
        </p>
      </div>

      <div>
        <a
          href={contactUrl}
          class="rounded-full border border-[color:var(--border-soft)] bg-white/70 px-4 py-2 text-sm font-medium text-neutral-700 shadow-sm transition duration-300 hover:border-primary-blue hover:text-primary-blue hover:shadow-md focus-visible:ring-3 dark:bg-white/5 dark:text-neutral-300 dark:hover:text-neutral-100"
        >
          {footerContent.ctaTitle}
        </a>
      </div>
    </div>

  </div>
</footer>
