---
import { Image } from "astro:assets";
import TextInput from "@components/ui/forms/input/TextInput.astro";
import TextAreaInput from "@components/ui/forms/input/TextAreaInput.astro";
import { inquiryTypes } from "@data/company";
import { EN_INQUIRY_TYPES } from "@data/company.en";
import contactWechatQr from "@images/contact-wechat-qr.jpg";

const {
  submitLabel = "提交咨询",
  compact = false,
  locale = "zh-CN",
  labels,
  inquiryTypeOptions,
} = Astro.props;

interface Props {
  submitLabel?: string;
  compact?: boolean;
  locale?: string;
  inquiryTypeOptions?: readonly string[];
  labels?: {
    name?: string;
    company?: string;
    contact?: string;
    inquiryType?: string;
    details?: string;
    statusIdle?: string;
    statusSubmitting?: string;
    successTitle?: string;
    successDescription?: string;
    resetText?: string;
    successStatus?: string;
    failureStatus?: string;
  };
}

const formClass = compact ? "grid gap-4" : "grid gap-6";
const inquiryOptions = inquiryTypeOptions ?? (locale.startsWith("en") ? EN_INQUIRY_TYPES : inquiryTypes);

const copy = {
  name: labels?.name ?? "姓名",
  company: labels?.company ?? "公司名称",
  contact: labels?.contact ?? "联系方式",
  inquiryType: labels?.inquiryType ?? "需求类型",
  details: labels?.details ?? "需求描述",
  statusIdle: labels?.statusIdle ?? "填写后我们会尽快与你联系。",
  statusSubmitting: labels?.statusSubmitting ?? "正在提交，请稍候…",
  successTitle: labels?.successTitle ?? "提交成功，欢迎微信继续沟通",
  successDescription:
    labels?.successDescription ?? "我们已收到你的需求，也可以直接扫码添加微信继续沟通。",
  resetText: labels?.resetText ?? "继续填写",
  successStatus: labels?.successStatus ?? "提交成功，我们会尽快与你联系。",
  failureStatus: labels?.failureStatus ?? "提交失败，请稍后重试。",
};
---

<div class="space-y-4" data-inquiry-root>
  <form class={formClass} data-inquiry-form>
    <div class="grid gap-4" data-inquiry-form-body>
      <TextInput id="contact-name" label={copy.name} name="name" />
      <TextInput id="contact-company" label={copy.company} name="company" />
      <TextInput id="contact-channel" label={copy.contact} name="contact" />
      <div>
        <label for="contact-inquiry-type" class="sr-only">{copy.inquiryType}</label>
        <select
          id="contact-inquiry-type"
          name="inquiryType"
          class="block w-full rounded-lg border border-neutral-200 bg-neutral-50 px-4 py-3 text-sm text-neutral-700 focus:border-neutral-200 focus:outline-hidden focus:ring-3 focus:ring-neutral-400 disabled:pointer-events-none disabled:opacity-50 dark:border-neutral-600 dark:bg-neutral-700/30 dark:text-neutral-300 dark:focus:ring-1"
        >
          {inquiryOptions.map((item) => <option value={item}>{item}</option>)}
        </select>
      </div>
      <TextAreaInput id="contact-details" label={copy.details} name="details" />
      <button
        type="submit"
        class="inline-flex items-center justify-center rounded-lg bg-zinc-600 px-4 py-3 text-sm font-bold text-white transition duration-300 hover:bg-zinc-500"
      >
        {submitLabel}
      </button>
    </div>
    <p
      class="text-sm text-neutral-600 dark:text-neutral-400"
      data-inquiry-status
      aria-live="polite"
    >
      {copy.statusIdle}
    </p>
  </form>

  <div
    class="hidden rounded-2xl border border-neutral-200 bg-white p-6 text-center shadow-sm dark:border-neutral-700 dark:bg-neutral-900"
    data-inquiry-success-card
  >
    <div class="mx-auto flex max-w-sm flex-col items-center gap-4">
      <div>
        <h3
          class="text-xl font-bold text-neutral-800 dark:text-neutral-100"
          data-inquiry-success-title
          tabindex="-1"
        >
          {copy.successTitle}
        </h3>
        <p class="mt-2 text-sm text-neutral-600 dark:text-neutral-400">
          {copy.successDescription}
        </p>
      </div>
      <div class="overflow-hidden rounded-2xl border border-neutral-200 bg-white p-3 shadow-sm dark:border-neutral-700 dark:bg-neutral-950">
        <Image
          src={contactWechatQr}
          alt="补全星科技联系微信二维码"
          class="mx-auto h-auto w-64 max-w-full rounded-xl"
          widths={[256, 384]}
          sizes="(max-width: 640px) 80vw, 256px"
        />
      </div>
      <button
        type="button"
        class="inline-flex items-center justify-center rounded-lg bg-zinc-600 px-5 py-3 text-sm font-bold text-white transition duration-300 hover:bg-zinc-500"
        data-inquiry-reset
      >
        {copy.resetText}
      </button>
    </div>
  </div>
</div>

<script is:inline>
  const roots = Array.from(document.querySelectorAll("[data-inquiry-root]"));

  roots.forEach((root) => {
    if (!(root instanceof HTMLElement)) return;

    const form = root.querySelector("[data-inquiry-form]");
    const formBody = root.querySelector("[data-inquiry-form-body]");
    const successCard = root.querySelector("[data-inquiry-success-card]");
    const successTitle = root.querySelector("[data-inquiry-success-title]");
    const resetButton = root.querySelector("[data-inquiry-reset]");

    if (!(form instanceof HTMLFormElement)) return;

    const status = form.querySelector("[data-inquiry-status]");
    const submitButton = form.querySelector('button[type="submit"]');

    const setSuccessView = (showSuccess) => {
      if (formBody instanceof HTMLElement) {
        formBody.classList.toggle("hidden", showSuccess);
      }

      if (successCard instanceof HTMLElement) {
        successCard.classList.toggle("hidden", !showSuccess);
      }
    };

    form.addEventListener("submit", async (event) => {
      event.preventDefault();

      const formData = new FormData(form);
      const payload = Object.fromEntries(formData.entries());

      if (status instanceof HTMLElement) {
        status.textContent = copy.statusSubmitting;
      }

      if (submitButton instanceof HTMLButtonElement) {
        submitButton.disabled = true;
      }

      try {
        const response = await fetch("/api/contact", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify(payload),
        });

        const result = await response.json();

        if (!response.ok || !result.ok) {
          throw new Error(result.message || copy.failureStatus);
        }

        form.reset();

        if (status instanceof HTMLElement) {
          status.textContent =
            result.message || copy.successStatus;
        }

        setSuccessView(true);

        if (successTitle instanceof HTMLElement) {
          successTitle.focus();
        } else if (resetButton instanceof HTMLButtonElement) {
          resetButton.focus();
        }
      } catch (error) {
        if (status instanceof HTMLElement) {
          status.textContent =
            error instanceof Error ? error.message : copy.failureStatus;
        }
      } finally {
        if (submitButton instanceof HTMLButtonElement) {
          submitButton.disabled = false;
        }
      }
    });

    if (resetButton instanceof HTMLButtonElement) {
      resetButton.addEventListener("click", () => {
        if (status instanceof HTMLElement) {
          status.textContent = copy.statusIdle;
        }

        setSuccessView(false);
      });
    }
  });
</script>
