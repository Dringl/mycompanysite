---
import ContactIconBlock from "@components/ui/blocks/ContactIconBlock.astro";
import InquiryForm from "@components/sections/misc/InquiryForm.astro";
import Icon from "@components/ui/icons/Icon.astro";
import { COMPANY_INFO, contactHighlights } from "@data/company";

const title = "联系我们";
const subTitle = COMPANY_INFO.contactIntro;
const formTitle = "提交咨询需求";
const formSubTitle = "填写基础信息后，我们会尽快与你联系。";
---

<section class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
  <div class="mx-auto max-w-2xl lg:max-w-5xl">
    <div class="text-center">
      <h1 class="text-balance text-2xl font-bold tracking-tight text-neutral-800 dark:text-neutral-200 md:text-4xl md:leading-tight">
        {title}
      </h1>
      <p class="mt-2 text-pretty text-neutral-600 dark:text-neutral-400">
        {subTitle}
      </p>
    </div>

    <div class="mt-12 grid items-start gap-6 lg:grid-cols-[minmax(0,1.08fr)_minmax(0,0.92fr)] lg:gap-16">
      <div class="rounded-2xl border border-white/10 bg-white/5 p-4 backdrop-blur-sm sm:p-6 lg:p-8">
        <h2 class="mb-2 text-xl font-bold text-neutral-700 dark:text-neutral-300">
          {formTitle}
        </h2>
        <p class="mb-8 text-sm text-neutral-600 dark:text-neutral-400">
          {formSubTitle}
        </p>
        <InquiryForm submitLabel={COMPANY_INFO.ctaLabel} />
      </div>

      <div class="flex h-full flex-col divide-y divide-neutral-300 rounded-2xl border border-white/10 bg-white/5 px-4 backdrop-blur-sm sm:px-6 lg:px-8 dark:divide-neutral-700">
        {
          contactHighlights.map((item, index) => (
            <ContactIconBlock
              heading={item.heading}
              content={item.content}
              isLinkVisible={item.isLinkVisible}
              linkTitle={item.linkTitle}
              linkURL={item.linkURL}
              isArrowVisible={item.isArrowVisible}
            >
              <Icon
                name={index === 0 ? "chatBubble" : index === 1 ? "briefcase" : index === 2 ? "openInNew" : "question"}
              />
            </ContactIconBlock>
          ))
        }
      </div>
    </div>
  </div>
</section>
