---
import ContactIconBlock from "@components/ui/blocks/ContactIconBlock.astro";
import InquiryForm from "@components/sections/misc/InquiryForm.astro";
import Icon from "@components/ui/icons/Icon.astro";
import { COMPANY_INFO } from "@data/company";
import { contactHighlightCards as contactHighlightCardsSource } from "@data_files/contact-highlights.mjs";

interface ContactHighlightCard {
  heading: string;
  content: string;
  icon: string;
  isLinkVisible: boolean;
  linkTitle: string;
  linkURL: string;
  isArrowVisible: boolean;
}

interface InquiryFormLabels {
  name?: string;
  company?: string;
  contact?: string;
  inquiryType?: string;
  details?: string;
  statusIdle?: string;
  statusSubmitting?: string;
  successTitle?: string;
  successDescription?: string;
  resetText?: string;
  successStatus?: string;
  failureStatus?: string;
}

interface Props {
  title?: string;
  subTitle?: string;
  formTitle?: string;
  formSubTitle?: string;
  submitLabel?: string;
  phoneLabel?: string;
  phoneName?: string;
  phoneNumber?: string;
  contactHighlightCards?: ContactHighlightCard[];
  locale?: string;
  inquiryTypeOptions?: readonly string[];
  inquiryFormLabels?: InquiryFormLabels;
}

const {
  title = "联系我们",
  subTitle = COMPANY_INFO.contactIntro,
  formTitle = "提交咨询需求",
  formSubTitle = "填写基础信息后，我们会尽快与你联系。",
  submitLabel = COMPANY_INFO.ctaLabel,
  phoneLabel = "咨询电话",
  phoneName = "刘先生",
  phoneNumber = "18622472119",
  contactHighlightCards = contactHighlightCardsSource as ContactHighlightCard[],
  locale = "zh-CN",
  inquiryTypeOptions,
  inquiryFormLabels,
} = Astro.props;
---

<section class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
  <div class="mx-auto max-w-2xl lg:max-w-5xl">
    <div class="text-center">
      <h1 class="text-balance text-2xl font-bold tracking-tight text-neutral-800 dark:text-neutral-200 md:text-4xl md:leading-tight">
        {title}
      </h1>
      <p class="mt-2 text-pretty text-neutral-600 dark:text-neutral-400">
        {subTitle}
      </p>
    </div>

    <div class="mt-12 grid items-start gap-6 lg:grid-cols-[minmax(0,1.08fr)_minmax(0,0.92fr)] lg:gap-16">
      <div class="rounded-2xl border border-white/10 bg-white/5 p-4 backdrop-blur-sm sm:p-6 lg:p-8">
        <h2 class="mb-2 text-xl font-bold text-neutral-700 dark:text-neutral-300">
          {formTitle}
        </h2>
        <p class="mb-8 text-sm text-neutral-600 dark:text-neutral-400">
          {formSubTitle}
        </p>
        <InquiryForm
          submitLabel={submitLabel}
          locale={locale}
          inquiryTypeOptions={inquiryTypeOptions}
          labels={inquiryFormLabels}
        />
      </div>

      <div class="flex h-full flex-col divide-y divide-neutral-300 rounded-2xl border border-white/10 bg-white/5 px-4 backdrop-blur-sm sm:px-6 lg:px-8 dark:divide-neutral-700">
        <div class="flex items-start gap-x-7 py-6">
          <div class="mt-1.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-primary-blue/12 text-primary-blue dark:bg-primary-blue/18">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M2.25 4.5a2.25 2.25 0 0 1 2.25-2.25h2.17c.52 0 .98.36 1.1.86l.75 3a1.125 1.125 0 0 1-.32 1.1l-1.3 1.3a11.26 11.26 0 0 0 5.59 5.59l1.3-1.3a1.125 1.125 0 0 1 1.1-.32l3 .75c.5.12.86.58.86 1.1v2.17a2.25 2.25 0 0 1-2.25 2.25h-.75C8.7 18.75 2.25 12.3 2.25 4.5v0Z"></path>
            </svg>
          </div>
          <div class="grow">
            <h3 class="font-bold text-neutral-700 dark:text-neutral-300">{phoneLabel}</h3>
            <p class="mt-1 text-sm text-neutral-600 dark:text-neutral-400">{phoneName}</p>
            <a
              class="mt-2 inline-flex items-center gap-x-2 rounded-lg text-sm font-medium text-zinc-600 outline-hidden ring-zinc-500 transition duration-300 hover:text-zinc-800 focus-visible:ring-3 dark:text-zinc-400 dark:ring-zinc-200 dark:hover:text-zinc-200 dark:focus:outline-hidden dark:focus:ring-1"
              href={`tel:${phoneNumber}`}
            >
              {phoneNumber}
            </a>
          </div>
        </div>
        {
          contactHighlightCards.map((item) => (
            <ContactIconBlock
              heading={item.heading}
              content={item.content}
              isLinkVisible={item.isLinkVisible}
              linkTitle={item.linkTitle}
              linkURL={item.linkURL}
              isArrowVisible={item.isArrowVisible}
            >
              <Icon name={item.icon} />
            </ContactIconBlock>
          ))
        }
      </div>
    </div>
  </div>
</section>
