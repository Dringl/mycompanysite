---
import LogoIcon from "@/components/ui/icons/LogoIcon.astro";
import PrimaryCTA from "@/components/ui/buttons/PrimaryCTA.astro";
import SecondaryCTA from "@/components/ui/buttons/SecondaryCTA.astro";

const {
  tagline,
  title,
  brandTitle,
  subTitle,
  primaryBtnText,
  primaryBtnUrl,
  secondaryBtnText,
  secondaryBtnUrl,
} = Astro.props;

const titleLines = title.split("\n").filter(Boolean);

interface Props {
  tagline?: string;
  title: string;
  brandTitle?: string;
  subTitle?: string;
  primaryBtnText?: string;
  primaryBtnUrl?: string;
  secondaryBtnText?: string;
  secondaryBtnUrl?: string;
}
---

<section class="relative mx-auto grid min-h-[88vh] max-w-screen place-items-center overflow-hidden px-4 sm:px-6 lg:px-8">
  <div class="absolute inset-x-0 top-0 -z-10 h-72 bg-radial-[circle_at_top] from-primary-blue/18 via-transparent to-transparent blur-2xl"></div>
  <div class="absolute inset-x-0 top-10 -z-10 flex justify-center opacity-55">
    <LogoIcon h="960" className="text-[color:var(--text-strong)]/6 dark:text-white/10" />
  </div>
  <div class="z-10 mx-auto max-w-6xl text-center">
    {
      tagline && (
        <span class="inline-flex rounded-full border border-[color:var(--border-soft)] bg-[color:var(--surface-1)]/80 px-4 py-2 text-xs font-medium tracking-[0.24em] text-[color:var(--text-body)] uppercase backdrop-blur-sm">
          {tagline}
        </span>
      )
    }
    <h1 class="mt-6 font-bebas text-[3.6rem] leading-none font-bold tracking-normal text-[color:var(--text-strong)] uppercase sm:text-[5rem] lg:text-[6.8rem]">
      {titleLines.map((line) => <span class="block">{line}</span>)}
    </h1>
    {
      brandTitle && (
        <h2 class="font-bebas from-[color:var(--text-strong)] via-primary-blue to-[color:var(--text-muted)] bg-gradient-to-b bg-clip-text text-[3rem] leading-none font-bold tracking-[-0.08em] text-transparent uppercase sm:text-[5rem] lg:text-[6.4rem]">
          {brandTitle}
        </h2>
      )
    }
    {
      subTitle && (
        <p class="mx-auto mt-6 max-w-3xl text-pretty text-base leading-8 text-[color:var(--text-body)] md:text-lg">
          {subTitle}
        </p>
      )
    }
    <div class="mt-8 flex flex-col justify-center gap-4 sm:flex-row">
      {
        primaryBtnText && primaryBtnUrl && (
          <PrimaryCTA title={primaryBtnText} url={primaryBtnUrl} />
        )
      }
      {
        secondaryBtnText && secondaryBtnUrl && (
          <SecondaryCTA title={secondaryBtnText} url={secondaryBtnUrl} />
        )
      }
    </div>
  </div>
</section>
