[Unit]
Description=BQ Star Astro site
After=network.target

[Service]
Type=simple
WorkingDirectory=/var/www/bq-star/current
EnvironmentFile=/etc/bq-star.env
ExecStart=/usr/bin/env node ./dist/server/entry.mjs
Restart=always
RestartSec=5
User=www-data
Group=www-data

[Install]
WantedBy=multi-user.target
